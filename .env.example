# DOT Corridor Communicator - API Credentials
# Copy this file to .env and fill in your actual credentials

# CARS Program (Iowa, Kansas, Nebraska, Indiana, Minnesota)
# Request credentials at: https://www.carsprogram.org/
CARS_USERNAME=your_username_here
CARS_PASSWORD=your_password_here

# Nevada DOT
# Request API key at: https://www.nvroads.com/
NEVADA_API_KEY=your_nevada_api_key_here

# Ohio DOT
# Request API key at: https://publicapi.ohgo.com/
OHIO_API_KEY=your_ohio_api_key_here

# Texas DOT (Socrata WZDx feed)
# Request an app token at: https://data.texas.gov/
TXDOT_API_KEY=your_txdot_api_key_here

# Note: New Jersey and Utah APIs do not require authentication

# ============================================================================
# V2X / ITS CodeHub ODE Integration
# ============================================================================

# MongoDB for ODE (change password in production)
MONGO_USERNAME=ode
MONGO_PASSWORD=odepassword

# ODE DDS - USDOT Situation Data Warehouse (optional)
# Leave blank if not connecting to USDOT SDW
ODE_DDS_CAS_URL=
ODE_DDS_CAS_USERNAME=
ODE_DDS_CAS_PASSWORD=

# Docker Host IP (usually leave as default)
DOCKER_HOST_IP=127.0.0.1

# ============================================================================
# Additional Services
# ============================================================================

# Database
DATABASE_URL=

# JWT Secret (change in production)
JWT_SECRET=your_secret_key_here

# OpenAI (optional, for AI features)
OPENAI_API_KEY=

# SendGrid (optional, for email notifications)
SENDGRID_API_KEY=
